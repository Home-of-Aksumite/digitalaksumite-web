# Digital Aksumite - Environment Variables Template

# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to version control.


# CMS (Payload) Configuration

NEXT_PUBLIC_CMS_API_URL=http://localhost:8000
# Optional: set if your Payload instance requires auth for reads/writes
# NEXT_PUBLIC_CMS_API_TOKEN=your_cms_api_token_here

# Application Configuration

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development


# Security Configuration

# Generate a strong random string for cookie signing
COOKIE_SECRET=your_random_secret_key_here_min_32_chars

# Rate limiting (requests per minute)
RATE_LIMIT_MAX_REQUESTS=100

# Analytics & Monitoring (Optional)

# NEXT_PUBLIC_GA_ID=your_google_analytics_id
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_site_verification_token
# SENTRY_DSN=your_sentry_dsn


# Email/Form Configuration (Optional - if using external services)

# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# CONTACT_EMAIL=contact@digitalaksumite.com
